APP_ENV=development
APP_NAME=historical-pump-scanner
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pump
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me
MARKET_DATA_PROVIDER=polygon
POLYGON_API_KEY=
MARKET_DATA_BASE_URL=https://api.massive.com
UNIVERSE_SOURCES=polygon,finviz
