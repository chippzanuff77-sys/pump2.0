MIN_AVG_DOLLAR_VOLUME=500000
PUMP_MULTIPLIER=4.0
PUMP_LOOKAHEAD_DAYS=60
PUMP_BASE_LOOKBACK_DAYS=60
WORKER_POLL_SECONDS=3600
